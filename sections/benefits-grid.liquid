<section class="section" id="benefits">
  <div class="page-width">
    <div class="section-header">
      <h2>{{ 'sections.benefits.title' | t }}</h2>
      <p>{{ 'sections.benefits.subtitle' | t }}</p>
      <div class="section-divider"></div>
    </div>

    <div class="benefits-grid">
      <div class="benefit-card">
        <div class="benefit-icon">💎</div>
        <h3 class="benefit-title">{{ 'sections.benefits.b1_title' | t }}</h3>
        <p class="benefit-text">{{ 'sections.benefits.b1_desc' | t }}</p>
      </div>

      <div class="benefit-card">
        <div class="benefit-icon">✨</div>
        <h3 class="benefit-title">{{ 'sections.benefits.b2_title' | t }}</h3>
        <p class="benefit-text">{{ 'sections.benefits.b2_desc' | t }}</p>
      </div>

      <div class="benefit-card">
        <div class="benefit-icon">🌸</div>
        <h3 class="benefit-title">{{ 'sections.benefits.b3_title' | t }}</h3>
        <p class="benefit-text">{{ 'sections.benefits.b3_desc' | t }}</p>
      </div>

      <div class="benefit-card">
        <div class="benefit-icon">🌙</div>
        <h3 class="benefit-title">{{ 'sections.benefits.b4_title' | t }}</h3>
        <p class="benefit-text">{{ 'sections.benefits.b4_desc' | t }}</p>
      </div>

      <div class="benefit-card">
        <div class="benefit-icon">🌿</div>
        <h3 class="benefit-title">{{ 'sections.benefits.b5_title' | t }}</h3>
        <p class="benefit-text">{{ 'sections.benefits.b5_desc' | t }}</p>
      </div>

      <div class="benefit-card">
        <div class="benefit-icon">🎁</div>
        <h3 class="benefit-title">{{ 'sections.benefits.b6_title' | t }}</h3>
        <p class="benefit-text">{{ 'sections.benefits.b6_desc' | t }}</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Benefits Grid",
  "settings": [],
  "presets": [
    {
      "name": "Benefits Grid"
    }
  ]
}
{% endschema %}
